{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Phoenix",
  "scopeName": "source.phoenix",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.phoenix",
          "begin": "/\\*\\*(?!/)",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        },
        {
          "name": "comment.block.phoenix",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        },
        {
          "name": "comment.line.double-slash.phoenix",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.phoenix",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.phoenix",
              "match": "\\\\[\\\\\"nrt0]"
            },
            {
              "name": "constant.character.escape.phoenix",
              "match": "\\{\\{|\\}\\}"
            },
            {
              "name": "meta.interpolation.phoenix",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.phoenix" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.phoenix" }
              },
              "patterns": [
                { "include": "#comments" },
                { "include": "#numbers" },
                { "include": "#constants" },
                { "include": "#functions" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#operators" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.phoenix",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.phoenix",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.phoenix",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.self.phoenix",
          "match": "\\bself\\b"
        },
        {
          "name": "constant.language.phoenix",
          "match": "\\b(None)\\b"
        },
        {
          "name": "support.constant.phoenix",
          "match": "\\b(Ok|Err|Some)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.type.phoenix",
          "match": "\\b(function|struct|enum|trait|impl|type)\\b"
        },
        {
          "name": "keyword.control.phoenix",
          "match": "\\b(if|else|while|for|in|match|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.phoenix",
          "match": "\\b(let|mut)\\b"
        },
        {
          "name": "keyword.other.endpoint.phoenix",
          "match": "\\b(endpoint|body|response|error|omit|pick|partial|query|where|schema)\\b"
        },
        {
          "name": "keyword.other.http-method.phoenix",
          "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.phoenix",
          "match": "\\b(Int|Float|String|Bool|Void)\\b"
        },
        {
          "name": "support.type.generic.phoenix",
          "match": "\\b(List|Map|Option|Result)\\b"
        },
        {
          "comment": "PascalCase type names (user-defined structs, enums, traits)",
          "name": "entity.name.type.phoenix",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.phoenix",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.phoenix",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.range.phoenix",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.try.phoenix",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.comparison.phoenix",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.compound.phoenix",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.assignment.phoenix",
          "match": "="
        },
        {
          "name": "keyword.operator.logical.phoenix",
          "match": "&&|\\|\\||!(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.phoenix",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function definition: function name(",
          "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "storage.type.phoenix" },
            "2": { "name": "entity.name.function.phoenix" }
          }
        },
        {
          "comment": "Function/method call: name(",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.phoenix" }
          }
        },
        {
          "comment": "Endpoint declaration: endpoint name:",
          "match": "\\b(endpoint)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "keyword.other.endpoint.phoenix" },
            "2": { "name": "entity.name.function.phoenix" }
          }
        },
        {
          "comment": "Struct/enum/trait declaration: struct Name",
          "match": "\\b(struct|enum|trait)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.phoenix" },
            "2": { "name": "entity.name.type.phoenix" }
          }
        },
        {
          "comment": "Type alias: type Name",
          "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.phoenix" },
            "2": { "name": "entity.name.type.phoenix" }
          }
        },
        {
          "comment": "Impl block: impl TypeName or impl Trait for TypeName",
          "match": "\\b(impl)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.phoenix" },
            "2": { "name": "entity.name.type.phoenix" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.phoenix",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
